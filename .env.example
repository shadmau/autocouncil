# API keys — only set the ones you actually use
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Optional: override default models (comma-separated, exactly 3)
# Use openai/responses/ prefix for GPT-5.x models to enable reasoning via the Responses API
# COUNCIL_MODELS=openai/responses/gpt-5.4,claude-opus-4-6,gemini/gemini-3.1-pro-preview

# Optional: default reasoning effort (low | medium | high) — do not set if using --thinking on the CLI
# high is recommended: maps to xhigh on OpenAI, adaptive thinking on Claude
# COUNCIL_THINKING=high

# Optional: directory for per-run debug logs
# COUNCIL_LOG_DIR=./logs